APP_NAME=EcoScan API
ENV=development
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend-domain.vercel.app
CORS_ORIGIN_REGEX=https://.*\.vercel\.app
MODEL_PATH=./models/best_model.keras
MODEL_INPUT_SIZE=300
MODEL_CLASSES=Anorganik,B3,Kertas,Organik,Residu
MAX_UPLOAD_SIZE_MB=8
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_HISTORY_TABLE=scan_history
